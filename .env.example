# Database
DATABASE_URL=postgresql://user:password@host:port/database

# OpenAI (for AI enrichment of listing data)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4-mini

# Proxy (optional)
# PROXY_URL=http://user:pass@proxy:port

# Kleinanzeigen (203=Wohnung mieten, 205=Haus mieten, 196=Wohnung kaufen, 208=Haus kaufen)
# KA_AUTH: capture from Android app traffic (Authorization: Basic <value>)
KA_AUTH=
KA_USER_AGENT=okhttp/4.10.0
KA_QUERY=
KA_LOCATION_ID=7667
KA_DISTANCE=10
KA_CATEGORY_IDS=203,205,196,208

# ImmoScout24 (apartmentrent, apartmentbuy, housebuy, houserent)
# IS24_USER_AGENT: capture from iOS app traffic (User-Agent header)
IS24_USER_AGENT=
IS24_REAL_ESTATE_TYPES=apartmentrent,apartmentbuy,housebuy
IS24_GEOCOORDINATES=49.79426;9.92748;5.0
IS24_PRICE_MIN=0
IS24_PRICE_MAX=0

# Immowelt (each search: distributionTypes|estateTypes, separated by ;)
IW_SEARCHES=Rent|Apartment,House;Buy,Buy_Auction,Compulsory_Auction|House,Apartment
IW_LOCATIONS=AD08DE7873

# Scheduling
INTERVAL_MIN=2220
INTERVAL_MAX=4620
ACTIVE_HOUR_START=8
ACTIVE_HOUR_END=22
TIMEZONE=Europe/Berlin
